---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { contactContent } from '../content/contact';
---

<Layout title="Contact">
  <!-- Hero -->
  <section class="hero backdrop-grid">
    <div class="container hero-inner">
      <span class="eyebrow">{contactContent.hero.eyebrow}</span>
      <h1 class="hero-title">
        {contactContent.hero.title}{' '}
        <span class="display-serif">{contactContent.hero.titleAccent}</span>
      </h1>
      <p class="hero-description">{contactContent.hero.description}</p>
      <div class="hero-cta">
        <Button href={`mailto:${contactContent.contact.methods[0].value}`} variant="primary" size="large" external>
          {contactContent.demo.benefits[0].includes('walkthrough') ? 'Email us' : 'Email us'}
        </Button>
        <Button href={`tel:${contactContent.contact.methods[1].value.replace(/[^+\d]/g, '')}`} variant="outline" size="large" external>
          Call the team
        </Button>
      </div>
    </div>
  </section>

  <!-- Demo + CTA Card -->
  <section class="demo section">
    <div class="container">
      <div class="demo-content">
        <div class="demo-info">
          <span class="eyebrow">{contactContent.demo.eyebrow}</span>
          <h2 class="demo-title">
            {contactContent.demo.title}{' '}
            <span class="display-serif">{contactContent.demo.titleAccent}</span>
          </h2>
          <p class="demo-description">{contactContent.demo.description}</p>
          <ul class="benefits-list">
            {contactContent.demo.benefits.map(benefit => (
              <li>{benefit}</li>
            ))}
          </ul>
        </div>
        <aside class="cta-card">
          <h3 class="cta-card-title">Start your journey with ARTE</h3>
          <p class="cta-card-body">
            We are not a faceless platform vendor. Reach the people who actually built ARTE — by phone or email.
          </p>
          <div class="cta-channels">
            <a class="cta-channel" href={`mailto:${contactContent.contact.methods[0].value}`}>
              <span class="cta-channel-label">Email</span>
              <span class="cta-channel-value">{contactContent.contact.methods[0].value}</span>
            </a>
            <a class="cta-channel" href={`tel:${contactContent.contact.methods[1].value.replace(/[^+\d]/g, '')}`}>
              <span class="cta-channel-label">Phone</span>
              <span class="cta-channel-value">{contactContent.contact.methods[1].value}</span>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Contact methods -->
  <section class="contact-methods section">
    <div class="container">
      <div class="section-heading center">
        <span class="eyebrow">{contactContent.contact.eyebrow}</span>
        <h2>
          {contactContent.contact.title}{' '}
          <span class="display-serif">{contactContent.contact.titleAccent}</span>
        </h2>
        <p class="lede" style="margin-left:auto; margin-right:auto;">{contactContent.contact.description}</p>
      </div>

      <div class="methods-grid">
        {contactContent.contact.methods.map(method => (
          <div class="method-card">
            <div class="method-icon" aria-hidden="true">
              {method.type === 'Email' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="m3 7 9 6 9-6"/>
                </svg>
              )}
              {method.type === 'Phone' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/>
                </svg>
              )}
              {method.type === 'Address' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              )}
            </div>
            <h3 class="method-type">{method.type}</h3>
            {method.action ? (
              <a class="method-value" href={method.action}>{method.value}</a>
            ) : (
              <p class="method-value">{method.value}</p>
            )}
            <p class="method-description">{method.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="team section">
    <div class="container">
      <div class="team-card">
        <div class="team-text">
          <span class="eyebrow">{contactContent.team.eyebrow}</span>
          <h2 class="team-title">
            {contactContent.team.title}{' '}
            <span class="display-serif">{contactContent.team.titleAccent}</span>
          </h2>
          <p class="team-description">{contactContent.team.description}</p>
        </div>
        <div class="team-aside" aria-hidden="true">
          <div class="team-avatar">A</div>
          <div class="team-avatar">R</div>
          <div class="team-avatar">T</div>
          <div class="team-avatar">E</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: clamp(4rem, 8vw, 6.5rem) 0 clamp(3rem, 6vw, 5rem);
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    text-align: center;
    max-width: 880px;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin: var(--space-5) 0 var(--space-5);
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .hero-title .display-serif {
    display: block;
    margin-top: 0.15em;
  }

  .hero-description {
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    color: var(--color-ink-soft);
    max-width: 60ch;
    margin: 0 auto var(--space-7);
  }

  .hero-cta {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Demo */
  .demo {
    background: var(--color-surface-2);
  }

  .demo-content {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-8);
    align-items: stretch;
  }

  .demo-title {
    font-size: clamp(1.85rem, 4vw, 2.6rem);
    margin: var(--space-4) 0 var(--space-4);
    line-height: 1.05;
  }

  .demo-title .display-serif {
    display: block;
  }

  .demo-description {
    color: var(--color-ink-soft);
    margin: 0 0 var(--space-5);
    max-width: 50ch;
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-line);
  }

  .benefits-list li {
    padding: var(--space-4) 0 var(--space-4) var(--space-5);
    position: relative;
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-line);
    font-size: 1rem;
  }

  .benefits-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.4em;
    width: 14px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .cta-card {
    background: var(--color-ink);
    color: #ece9df;
    padding: clamp(2rem, 4vw, 3rem);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    inset: -40% -20% auto auto;
    width: 80%;
    height: 100%;
    background: radial-gradient(circle, rgba(47, 111, 237, 0.4) 0%, transparent 60%);
    filter: blur(28px);
    pointer-events: none;
  }

  .cta-card-title {
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 1.85rem;
    margin: 0;
    position: relative;
    z-index: 1;
    line-height: 1.1;
  }

  .cta-card-body {
    color: #c1bdb1;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .cta-channels {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .cta-channel {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    color: #ece9df;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .cta-channel:hover {
    background: rgba(158, 192, 255, 0.12);
    border-color: rgba(158, 192, 255, 0.3);
    color: #ffffff;
  }

  .cta-channel-label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #9ec0ff;
    font-weight: 600;
  }

  .cta-channel-value {
    font-size: 1.05rem;
    font-weight: 600;
    color: #ffffff;
  }

  /* Contact methods */
  .methods-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .method-card {
    background: var(--color-surface);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-line);
    text-align: left;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .method-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-line-strong);
    box-shadow: 0 18px 40px -24px rgba(31, 79, 192, 0.18);
  }

  .method-icon {
    width: 48px;
    height: 48px;
    background: var(--color-accent-soft);
    border-radius: var(--radius-md);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
    color: var(--color-accent-dark);
  }

  .method-icon svg {
    width: 24px;
    height: 24px;
  }

  .method-type {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-accent-dark);
    margin: 0 0 var(--space-2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .method-value {
    display: block;
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-ink);
    margin: 0 0 var(--space-2);
    font-weight: 500;
    text-decoration: none;
    line-height: 1.2;
    word-break: break-word;
  }

  a.method-value:hover {
    color: var(--color-accent-dark);
  }

  .method-description {
    color: var(--color-ink-muted);
    margin: 0;
    font-size: 0.92rem;
  }

  /* Team */
  .team {
    background: var(--color-bg-alt);
  }

  .team-card {
    background: var(--color-surface);
    padding: clamp(2.5rem, 5vw, 4rem);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-line);
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  .team-title {
    font-size: clamp(1.85rem, 4vw, 2.6rem);
    margin: var(--space-4) 0 var(--space-4);
    line-height: 1.05;
  }

  .team-title .display-serif {
    display: block;
  }

  .team-description {
    color: var(--color-ink-soft);
    margin: 0;
  }

  .team-aside {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  .team-avatar {
    aspect-ratio: 1;
    background: linear-gradient(135deg, var(--color-accent-soft) 0%, var(--color-accent-tint) 100%);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 600;
    color: var(--color-accent-dark);
    border: 1px solid var(--color-accent-soft);
  }

  /* Responsive */
  @media (max-width: 960px) {
    .demo-content {
      grid-template-columns: 1fr;
    }

    .team-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-cta {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
