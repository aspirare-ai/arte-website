---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { homeContent } from '../content/home';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="hero backdrop-grid">
    <div class="container hero-inner">
      <span class="eyebrow">{homeContent.hero.eyebrow}</span>
      <h1 class="hero-title">
        {homeContent.hero.title}
        <span class="display-serif">{homeContent.hero.titleAccent}</span>
      </h1>
      <p class="hero-description">{homeContent.hero.description}</p>
      <div class="hero-cta">
        <Button href="/contact" variant="primary" size="large">
          {homeContent.hero.cta.primary}
        </Button>
        <Button href="/platform" variant="outline" size="large">
          {homeContent.hero.cta.secondary}
        </Button>
      </div>

      <ul class="hero-stats">
        {homeContent.hero.stats.map(stat => (
          <li>
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Core Capabilities -->
  <section class="features section">
    <div class="container">
      <div class="section-heading center">
        <span class="eyebrow">{homeContent.coreFunctionalities.eyebrow}</span>
        <h2>
          {homeContent.coreFunctionalities.title}{' '}
          <span class="display-serif">{homeContent.coreFunctionalities.titleAccent}</span>
        </h2>
        <p class="lede" style="margin-left:auto; margin-right:auto;">
          {homeContent.coreFunctionalities.subtitle}
        </p>
      </div>

      <div class="features-grid">
        {homeContent.coreFunctionalities.features.map(feature => (
          <article class="feature-card card">
            <div class="feature-top">
              <span class="feature-number">{feature.number}</span>
              <span class="feature-icon" aria-hidden="true">
                {feature.icon === 'brain' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 3a3 3 0 0 0-3 3v.5A3.5 3.5 0 0 0 4 10a3 3 0 0 0 .8 5.6A3 3 0 0 0 9 21a3 3 0 0 0 3-3V6a3 3 0 0 0-3-3Z"/>
                    <path d="M15 3a3 3 0 0 1 3 3v.5A3.5 3.5 0 0 1 20 10a3 3 0 0 1-.8 5.6A3 3 0 0 1 15 21a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3Z"/>
                  </svg>
                )}
                {feature.icon === 'analytics' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 3v18h18"/>
                    <path d="M7 15l4-4 4 4 5-6"/>
                  </svg>
                )}
                {feature.icon === 'cycle' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12a9 9 0 1 1-3-6.7"/>
                    <path d="M21 4v5h-5"/>
                  </svg>
                )}
              </span>
            </div>
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-description">{feature.description}</p>
            <ul class="feature-bullets">
              {feature.bullets.map(b => <li>{b}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="benefits section">
    <div class="container">
      <div class="benefits-layout">
        <div class="section-heading">
          <span class="eyebrow">{homeContent.benefits.eyebrow}</span>
          <h2>
            {homeContent.benefits.title}{' '}
            <span class="display-serif">{homeContent.benefits.titleAccent}</span>
          </h2>
        </div>
        <div class="benefits-grid">
          {homeContent.benefits.items.map(item => (
            <div class="benefit-item">
              <span class="benefit-bullet" aria-hidden="true"></span>
              <h4 class="benefit-title">{item.title}</h4>
              <p class="benefit-body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Trust / Proof -->
  <section class="proof section">
    <div class="container">
      <div class="proof-card">
        <div class="proof-text">
          <span class="eyebrow">{homeContent.proof.eyebrow}</span>
          <h2 class="proof-headline">{homeContent.proof.headline}</h2>
          <p class="proof-body">{homeContent.proof.body}</p>
        </div>
        <ul class="proof-chips">
          {homeContent.proof.chips.map(chip => <li>{chip}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta section">
    <div class="container">
      <div class="final-cta-inner">
        <h2 class="final-cta-title">
          {homeContent.finalCta.title}
        </h2>
        <p class="final-cta-body">{homeContent.finalCta.body}</p>
        <div class="final-cta-actions">
          <Button href="/contact" variant="primary" size="large">{homeContent.finalCta.primary}</Button>
          <Button href="/contact" variant="ghost" size="large">{homeContent.finalCta.secondary}</Button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: clamp(4rem, 9vw, 7rem) 0 clamp(3.5rem, 7vw, 6rem);
    background: var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: auto -10% -40% auto;
    width: 60%;
    height: 70%;
    background: radial-gradient(circle, rgba(47, 111, 237, 0.18) 0%, transparent 60%);
    pointer-events: none;
    filter: blur(20px);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 920px;
  }

  .hero .eyebrow {
    margin-bottom: var(--space-5);
  }

  .hero-title {
    font-size: clamp(2.5rem, 6.5vw, 5.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-5);
  }

  .hero-title .display-serif {
    display: block;
    margin-top: 0.2em;
  }

  .hero-description {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: var(--color-ink-soft);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0 auto var(--space-7);
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .hero-stats {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
  }

  .hero-stats li {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-align: center;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--color-accent-dark);
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  /* Features */
  .features {
    background: var(--color-surface-2);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-5);
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .feature-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .feature-number {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-accent);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .feature-icon {
    display: inline-flex;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--color-accent-soft);
    color: var(--color-accent-dark);
    align-items: center;
    justify-content: center;
  }

  .feature-icon svg {
    width: 22px;
    height: 22px;
  }

  .feature-title {
    margin: 0;
    font-size: 1.5rem;
  }

  .feature-description {
    color: var(--color-ink-soft);
    margin: 0;
  }

  .feature-bullets {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .feature-bullets li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
  }

  .feature-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 12px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  /* Benefits */
  .benefits-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-8);
    align-items: start;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .benefit-item {
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-line);
  }

  .benefit-bullet {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .benefit-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-ink);
  }

  .benefit-body {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
  }

  /* Proof */
  .proof {
    background: var(--color-bg-alt);
  }

  .proof-card {
    background: var(--color-ink);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 5vw, 4rem);
    color: #ece9df;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-7);
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .proof-card::before {
    content: '';
    position: absolute;
    inset: -50% -10% auto auto;
    width: 60%;
    height: 130%;
    background: radial-gradient(circle, rgba(47, 111, 237, 0.45) 0%, transparent 60%);
    filter: blur(30px);
    pointer-events: none;
  }

  .proof-text {
    position: relative;
    z-index: 1;
  }

  .proof-text .eyebrow {
    background: rgba(158, 192, 255, 0.18);
    color: #c8d8ff;
  }

  .proof-headline {
    font-family: var(--font-display);
    color: #ffffff;
    font-size: clamp(1.6rem, 3.4vw, 2.5rem);
    margin: var(--space-4) 0 var(--space-4);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .proof-body {
    color: #c1bdb1;
    margin: 0;
  }

  .proof-chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    position: relative;
    z-index: 1;
  }

  .proof-chips li {
    background: rgba(255, 255, 255, 0.06);
    color: #ece9df;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.55rem 0.95rem;
    border-radius: var(--radius-pill);
    font-size: 0.88rem;
    font-weight: 500;
  }

  /* Final CTA */
  .final-cta-inner {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.5rem, 4vw, 3rem);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-xl);
  }

  .final-cta-title {
    margin-bottom: var(--space-3);
  }

  .final-cta-body {
    color: var(--color-ink-soft);
    margin: 0 auto var(--space-6);
    max-width: 50ch;
  }

  .final-cta-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .benefits-layout {
      grid-template-columns: 1fr;
    }

    .proof-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-stats {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .hero-cta {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
